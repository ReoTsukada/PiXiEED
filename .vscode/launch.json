{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "pwa-chrome",
            "request": "launch",
            "name": "PiXiEEDraw (prod)",
            "url": "http://127.0.0.1:8000/pixiedraw/",
            "webRoot": "${workspaceFolder}",
            "preLaunchTask": "Run PiXiEED static server"
        },
        {
            "type": "pwa-chrome",
            "request": "launch",
            "name": "PiXiEEDDraw.dev (split work)",
            "url": "http://127.0.0.1:8000/PiXiEEDDraw.dev/",
            "webRoot": "${workspaceFolder}",
            "preLaunchTask": "Run PiXiEED static server"
        },
        {
            "type": "pwa-chrome",
            "request": "launch",
            "name": "Open Home (index.html)",
            "file": "${workspaceFolder}/index.html"
        },
        {
            "type": "pwa-chrome",
            "request": "launch",
            "name": "Launch Chrome against localhost",
            "url": "http://localhost:8080",
            "webRoot": "${workspaceFolder}"
        }
    ]
}
