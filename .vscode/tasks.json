{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Run PiXiEED static server",
            "type": "shell",
            "command": "node",
            "args": [
                "scripts/static-server.mjs"
            ],
            "options": {
                "cwd": "${workspaceFolder}",
                "env": {
                    "PORT": "8000"
                }
            },
            "isBackground": true,
            "problemMatcher": {
                "owner": "custom",
                "pattern": {
                    "regexp": "^(.*)$",
                    "message": 1
                },
                "background": {
                    "activeOnStart": true,
                    "beginsPattern": ".",
                    "endsPattern": "Static server running at http://localhost:8000/"
                }
            },
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "clear": false
            },
            "runOptions": {
                "reevaluateOnRerun": true
            }
        }
    ]
}
